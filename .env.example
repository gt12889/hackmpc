# Google Gemini API key — powers the conversational analytics, policy reasoning,
# approval recommendations, and report summaries. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=AQ.Ab8RN6LY1tUqLjBpoNxLptmK7mzGpPiROEnhuVCr6FiepJhJvg
# Optional: override the model (default gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# --- Phone-call alerts (ElevenLabs Conversational AI + Twilio) ---
# Optional. When all four are set AND the Compliance "Phone alerts" toggle is on,
# new HIGH/CRITICAL compliance alerts trigger an interactive phone call.
# 1) Create a Conversational AI agent in ElevenLabs (read-only compliance reader).
# 2) Import your Twilio number into ElevenLabs; copy its phone-number id.
# Twilio TRIAL accounts can only call VERIFIED numbers.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
ALERT_PHONE_NUMBER=        # recipient in E.164, e.g. +15551234567

# --- Solana on-chain audit anchor (devnet, server keypair) ---
# Optional. When SOLANA_PAYER_SECRET is set, every report/approval/HIGH-CRITICAL-alert
# decision is notarized by writing a SHA-256 of its snapshot into a Solana Memo tx, giving a
# verifiable Explorer link + tamper detection. Run `npm run solana:setup` to generate and
# faucet-fund a devnet keypair and populate these automatically (writes to .env.local).
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
SOLANA_PAYER_SECRET=        # JSON array of the 64-byte secret key (set by solana:setup)
